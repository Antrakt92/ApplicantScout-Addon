    "C_Timer",
    "CanInspect",
    "ClearInspectPlayer",
    "CreateFrame",
    "GameTooltip",
    "GetAddOnMetadata",
    "GetAverageItemLevel",
    "GetBuildInfo",
    "GetCurrentRegion",
    "GetCVar",
    "GetInspectSpecialization",
    "GetNumGroupMembers",
    "GetRaidRosterInfo",
    "GetSpecialization",
    "GetSpecializationInfo",
    "GetSpecializationRoleByID",
    "GetTime",
    "GetUnitName",
    "InCombatLockdown",
    "IsAltKeyDown",
    "IsInGroup",
    "IsInInstance",
    "IsInRaid",
    "NotifyInspect",
    "Screenshot",
    "SendChatMessage",
    "SetCVar",
    "SlashCmdList",
    "UIParent",
    "UnitClass",
    "UnitExists",
    "UnitFullName",
    "UnitGroupRolesAssigned",
    "UnitGUID",
    "UnitIsGroupLeader",
    "UnitIsUnit",
