{
  "runtime.version": "Lua 5.1",
  "runtime.path": [
    "?.lua",
    "?/init.lua"
  ],
  "workspace.checkThirdParty": false,
  "diagnostics.globals": [
    "Ambiguate",
    "bit",
    "C_AddOns",
    "C_ChatInfo",
    "C_LFGList",
    "C_MythicPlus",
    "C_PaperDollInfo",
